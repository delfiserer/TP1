beneficiario = str(input('Nombre del beneficiario: '))
codigo = str(input('Ingrese codigo ICD10 de la enfermedad: '))
monto_base = int(input('Ingrese el monto base: '))

# Calculo del monto final
letra = codigo[0]
fijo = 25000

#Condicional segun la letra

if (letra >= 'A' and letra <= 'L') or (letra >= 'a' and letra <= 'l'):
    extra_letra = 25000
elif letra == 'U' or letra == 'u':
    extra_letra = 100000
else:
    extra_letra = 40000

monto = monto_base + fijo + extra_letra

#Resultados
print('Nombre del beneficiario :', beneficiario)
print('Codigo ICD10 de la enfermedad: ', codigo)
print('Nombre del capitulo :', capitulo)
print('Monto total del tratamiento: ', monto)
